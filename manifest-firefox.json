{
  "manifest_version": 2,
  "name": "Review Roulette",
  "version": "1.0",
  "description": "Pick random movies from your Letterboxd watchlist by blind review.",
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "scripts": ["service-worker.js"],
    "persistent": false
  },
  "permissions": [
    "https://letterboxd.com/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
